rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 使用者資料:登入者皆可讀(顧客頁要讀 name);文件由你手動在 Console 建立,程式不可寫
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 商品:登入者皆可讀;只有 admin 能新增/修改/刪除
    match /products/{productId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 代幣餘額:本人或 admin 可讀
    match /tokens/{userId} {
      allow read: if request.auth.uid == userId
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // 顧客只能在「餘額減少」時更新(購買扣款);admin 可任意改(發代幣)
      allow update: if (request.auth.uid == userId
                        && request.resource.data.balance < resource.data.balance)
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // 只有 admin 能建立 tokens 文件(第一次發代幣)
      allow create: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 訂單:本人或 admin 可讀;只能由本人建立;不可改/刪
    match /orders/{orderId} {
      allow read: if resource.data.userId == request.auth.uid
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow create: if request.auth.uid == request.resource.data.userId;
      allow update: if false;
      // 管理員可刪除訂單(代表「已兌換、結清」)
      allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 發代幣紀錄:登入者可讀;只有 admin 能建立;不可改/刪
    match /tokenLogs/{logId} {
      allow read: if request.auth != null;
      allow create: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update, delete: if false;
    }

    // 任務:登入者皆可讀;只有 admin 能新增/修改/刪除
    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 完成申請:本人或 admin 可讀
    match /taskClaims/{claimId} {
      allow read: if resource.data.userId == request.auth.uid
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';

      // 只能由本人建立,且狀態必須是 pending、獎勵金額必須等於該任務實際設定(防止偷改金額)
      allow create: if request.auth.uid == request.resource.data.userId
        && request.resource.data.status == 'pending'
        && request.resource.data.reward == get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId)).data.reward;

      // 只有 admin 能審核(核准/退回 → 改狀態);不可刪除
      allow update: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow delete: if false;
    }

    // 設定(盲盒等):登入者皆可讀;只有 admin 能寫
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 神祕獎品兌換(升級獎勵):本人或 admin 可讀
    match /mysteryRedemptions/{redeemId} {
      allow read: if resource.data.userId == request.auth.uid
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      // 只能由本人建立,且狀態為 pending(可兌換數量由前端依等級控管)
      allow create: if request.auth.uid == request.resource.data.userId
        && request.resource.data.status == 'pending';
      // 只有 admin 能標記已給(改狀態);不可刪除,保留兌換次數紀錄
      allow update: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow delete: if false;
    }
  }
}
